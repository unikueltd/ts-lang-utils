{
    "name": "TsLangUtils",
    "entryPoints": [
        "src/index.ts"
    ],
    "disableSources": true,
    "excludeExternals": true,
    "excludeInternal": true,
    "excludePrivate": true,
    "excludeProtected": true,
    "hideGenerator": true,
    "highlightLanguages": [
        "bash",
        "html",
        "js",
        "json",
        "jsx",
        "ts"
    ],
    "includeVersion": false,
    "navigationLinks": {
        "GitHub": "https://github.com/unikueltd/ts-lang-utils",
        "Unikue": "https://unikue.cn"
    },
    "plugin": [
        "@unikue/typedoc-plugin-raw-content",
        "@unikue/typedoc-theme-dumi"
    ],
    "theme": "dumi",
    "rawHeadEnds": [
        "<meta name='keywords' content='typescript, unikue, ts-lang-utils'/>"
    ],
    "rawFooterEnds": [
        "<div style='text-align: center'>Copyright &copy; 2026 Unikue Ltd. All rights reserved</div>"
    ],
    "logoImage": "https://unikueltd.github.io/assets/ico/logo-icon.svg",
    "logoWidth": 32,
    "logoHeight": 32,
    "logoTitle": "@unikue/ts-lang-utils",
    "navigationLinkTargets": {
        "GitHub": "_blank",
        "Unikue": "_blank"
    },
    "footerAlign": "center"
}
