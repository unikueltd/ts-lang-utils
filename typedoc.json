{
    "name": "TsLangUtils",
    "entryPoints": [
        "src/index.ts"
    ],
    "disableSources": true,
    "excludeExternals": true,
    "excludeInternal": true,
    "excludePrivate": true,
    "excludeProtected": true,
    "hideGenerator": true,
    "includeVersion": false,
    "navigationLinks": {
        "GitHub": "https://github.com/yookue/ts-lang-utils",
        "Yookue": "https://yookue.com"
    },
    "plugin": [
        "@yookue/typedoc-plugin-raw-content",
        "@yookue/typedoc-theme-dumi"
    ],
    "theme": "dumi",
    "rawHeadEnds": [
        "<meta name='keywords' content='typescript, yookue, ts-lang-utils'/>"
    ],
    "rawFooterEnds": [
        "<div style='text-align: center'>Copyright &copy; 2025 Yookue Ltd. All rights reserved</div>"
    ],
    "logoImage": "https://yookue.github.io/assets/ico/logo-icon.svg",
    "logoWidth": 32,
    "logoHeight": 32,
    "logoTitle": "@yookue/ts-lang-utils",
    "navigationLinkTargets": {
        "GitHub": "_blank",
        "Yookue": "_blank"
    },
    "footerAlign": "center"
}
