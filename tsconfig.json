{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "target": "es2020",
        "lib": ["dom", "es2022"],
        "declaration": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "noImplicitAny": false,
        "noUnusedLocals": true,
        "removeComments": true,
        "skipLibCheck": true,
        "strict": true,
        "types": ["node"],
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@unikue/ts-lang-utils": [
                "./src"
            ],
            "@unikue/ts-lang-utils/*": [
                "./src/*"
            ]
        }
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        "coverage",
        "dist",
        "docs-dist"
    ]
}
